# ─────────────────────────────────────────
# ORIGIN ADMIN PORTAL — 環境変数テンプレート
# このファイルを .env.local にコピーして値を設定
# .env.local は .gitignore に必ず追加すること
# ─────────────────────────────────────────

# Supabase プロジェクト URL（ダッシュボード > Project Settings > API）
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co

# Supabase Anon Key（公開鍵 - フロントで使用OK）
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# サイトURL（本番: VercelのURL、開発: localhost）
VITE_SITE_URL=http://localhost:5173

# ─────────────────────────────────────────
# Edge Functions 専用（Supabase Secrets に設定 - フロントには不要）
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=xxx
# ─────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SITE_URL=https://your-app.vercel.app
